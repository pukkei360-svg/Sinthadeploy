generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  firebaseUid   String?  @unique
  email         String   @unique
  name          String
  password      String?
  photoUrl      String?
  role          String   @default("client") // client, provider, admin
  phone         String?
  location      String?
  latitude      Float?
  longitude     Float?
  isVerified    Boolean  @default(false)
  isPro         Boolean  @default(false)
  proExpiry     DateTime?
  isBlocked     Boolean  @default(false)
  // Ban feature — created at runtime by src/lib/migrate-schema.ts
  // (prisma db push doesn't run on Vercel build, so we use raw SQL DDL
  // at app startup to add these columns idempotently)
  isBanned      Boolean  @default(false)
  banReason     String?
  bannedAt      DateTime?
  fcmToken      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  providerProfile ProviderProfile?
  bookingsAsClient Booking[] @relation("ClientBookings")
  bookingsAsProvider Booking[] @relation("ProviderBookings")
  reviewsGiven Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  sentMessages ChatMessage[] @relation("MessageSender")
  verifications VerificationDoc[]
  subscriptions Subscription[]
  passwordResetTokens PasswordResetToken[]
  claimsFiled Claim[] @relation("ClaimReporter")
  claimsAgainst Claim[] @relation("ClaimSubject")
  // Job marketplace relations
  jobsPosted Job[] @relation("JobClient")
  jobQuotes JobQuote[] @relation("JobQuoteProvider")
  // Phase 2 marketplace enhancement relations
  favorites Favorite[] @relation("ClientFavorites")
  favoritedBy Favorite[] @relation("ProviderFavoritedBy")
  savedAddresses SavedAddress[] @relation("ClientSavedAddresses")
}

// BannedEmail — email blacklist. Survives user deletion so banned users
// can't re-register with the same email. Created at runtime by
// src/lib/migrate-schema.ts
model BannedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  bannedAt  DateTime @default(now())
  bannedBy  String?
  createdAt DateTime @default(now())
}

// Claim — a user-filed report against a provider. Created at runtime by
// src/lib/migrate-schema.ts
model Claim {
  id          String   @id @default(cuid())
  reporterId  String
  subjectId   String
  bookingId   String?
  type        String
  severity    String   @default("medium")
  title       String
  description String
  status      String   @default("open")
  resolution  String?
  handledBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User  @relation("ClaimReporter", fields: [reporterId], references: [id])
  subject  User  @relation("ClaimSubject", fields: [subjectId], references: [id])

  @@index([subjectId])
  @@index([reporterId])
  @@index([status])
}

// NOTE: The ban/claims feature (isBanned, banReason, bannedAt columns on User,
// plus BannedEmail and Claim models) has been TEMPORARILY REMOVED from the
// schema because prisma db push is not running on the Vercel build, so the
// production DB doesn't have these columns — which breaks user registration
// and admin login.
//
// The feature code is still in the codebase (auth/sync, admin endpoints,
// AdminClaimsScreen, etc.) but it's all wrapped in defensive try/catch so
// it gracefully degrades when the tables/columns don't exist.
//
// To re-enable: run `npx prisma db push` manually against the production
// DATABASE_URL, then re-add the fields to the schema and redeploy.

model ServiceCategory {
  id          String @id @default(cuid())
  name        String
  icon        String?
  description String?
  order       Int    @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providers ProviderProfile[]
  jobs      Job[]
}

model ProviderProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  categoryId    String
  experience    String?
  skills        String?
  description   String?
  hourlyRate    Float?
  availability  String   @default("available") // available, busy, offline
  rating        Float    @default(0)
  totalReviews  Int      @default(0)
  totalBookings Int      @default(0)
  portfolioUrls String?  // JSON array of image URLs
  packages      String?  // JSON array of service packages (PRO)
  offers        String?  // JSON array of promotional offers (PRO)
  isFeatured    Boolean  @default(false)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings Booking[]      @relation("BookingProviderProfile")

  @@index([userId])
  @@index([categoryId])
}

model Booking {
  id          String   @id @default(cuid())
  clientId    String
  providerId  String
  service     String
  description String?
  date        DateTime
  time        String?
  status      String   @default("pending") // pending, accepted, in_progress, completed, cancelled, disputed
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Phase 2 marketplace enhancement fields ───────────────────────────
  // All nullable so existing rows are unaffected. Created at runtime by
  // src/lib/migrate-schema.ts (raw SQL DDL — prisma db push doesn't run
  // on Vercel build).
  cancelReason     String?  // why the booking was cancelled
  cancelledBy      String?  // 'client' | 'provider'
  rescheduledFrom  String?  // ISO date string before a reschedule
  rescheduledAt    DateTime? // when the reschedule happened
  price            Float?   // agreed/charged INR amount, set on completion
  beforePhotos     String?  // JSON array of Cloudinary URLs
  afterPhotos      String?  // JSON array of Cloudinary URLs

  client   User           @relation("ClientBookings", fields: [clientId], references: [id])
  provider User           @relation("ProviderBookings", fields: [providerId], references: [id], map: "Booking_provider_user_fkey")
  providerProfile ProviderProfile @relation("BookingProviderProfile", fields: [providerId], references: [userId], map: "Booking_provider_profile_fkey")
  review   Review?

  @@index([clientId])
  @@index([providerId])
  @@index([status])
}

// Favorite — a client's saved provider. Created at runtime by migrate-schema.ts.
// Lets clients bookmark providers they like for quick re-booking.
model Favorite {
  id         String   @id @default(cuid())
  clientId   String
  providerId String
  createdAt  DateTime @default(now())

  client   User           @relation("ClientFavorites", fields: [clientId], references: [id])
  provider User           @relation("ProviderFavoritedBy", fields: [providerId], references: [id])

  @@unique([clientId, providerId])
  @@index([clientId])
  @@index([providerId])
}

// SavedAddress — a client's saved booking address (Home, Office, etc.).
// Created at runtime by migrate-schema.ts. Lets clients pick from saved
// addresses in the booking form instead of re-typing every time.
model SavedAddress {
  id        String   @id @default(cuid())
  clientId  String
  label     String   // "Home", "Office", "Mom's house", etc.
  address   String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User @relation("ClientSavedAddresses", fields: [clientId], references: [id])

  @@index([clientId])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  authorId   String
  targetId   String
  rating     Int
  comment    String?
  photoUrls  String?  // JSON array
  createdAt  DateTime @default(now())

  author User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User    @relation("ReviewTarget", fields: [targetId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([targetId])
}

model ChatConversation {
  id           String   @id @default(cuid())
  participantA String
  participantB String
  bookingId    String?
  lastMessage  String?
  lastMessageAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages ChatMessage[]

  @@index([participantA])
  @@index([participantB])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("text") // text, image, voice, location
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model VerificationDoc {
  id         String   @id @default(cuid())
  userId     String
  // docType: 'identity' (Aadhaar + passport photo combined verification)
  // Legacy types 'aadhaar', 'selfie', 'address_proof' kept for backward compat
  docType    String
  docUrl     String   // Primary doc URL (Aadhaar photo for 'identity' type)

  // ── Phase 1 identity verification fields ──────────────────────
  // Full name as the user entered it (should match the name on the Aadhaar card).
  // Admin compares this manually with the name visible on aadhaarPhotoUrl.
  fullNameAsPerAadhaar String?
  // URL of the uploaded Aadhaar card FRONT photo (has name + photo + DOB)
  aadhaarPhotoUrl String?
  // URL of the uploaded Aadhaar card BACK photo (has address + QR code)
  aadhaarBackPhotoUrl String?
  // URL of the uploaded passport-size photo (stored in Cloudinary 'verifications' folder)
  // Auto-checked for face presence via Cloudinary's face detection on upload.
  passportPhotoUrl String?
  // Whether Cloudinary's AI detected a face in the passport photo (true/false/null)
  // null = not checked yet, true = face detected (good), false = no face (rejected at upload)
  faceDetected Boolean?

  status     String   @default("pending") // pending, verified, rejected
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  plan            String   @default("pro")
  razorpayOrderId String?
  razorpayPaymentId String?
  amount          Float
  currency        String   @default("INR")
  status          String   @default("active") // active, expired, cancelled
  startDate       DateTime @default(now())
  endDate         DateTime
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // booking, chat, review, system, pro
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ── Job Marketplace ──────────────────────────────────────────────
// A client posts a Job describing what they need. Providers in the
// matching category see it and send JobQuotes (price + message).
// The client reviews quotes and accepts one — which auto-creates a
// Booking with that provider.

model Job {
  id            String   @id @default(cuid())
  clientId      String   // the user who posted the job
  categoryId    String   // electrician, tutor, etc.
  title         String   // short — "Fix ceiling fan"
  description   String   // detailed — what's broken, when, where
  location      String?  // auto-filled from client profile, editable
  budget        Float?   // nullable = "open to quotes"
  preferredDate DateTime? // optional — when the client wants it done
  urgency       String   @default("flexible") // today, this_week, flexible
  // Optional photos of the job (e.g. photo of broken fan, room layout).
  // Stored as JSON array of Cloudinary URLs. Max 2 photos per job.
  // Clients attach these so providers can see the problem before quoting.
  photoUrls     String?  // JSON array: ["https://res.cloudinary.com/...", "..."]
  status        String   @default("open") // open, awarded, closed, cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client   User             @relation("JobClient", fields: [clientId], references: [id], onDelete: Cascade)
  category ServiceCategory  @relation(fields: [categoryId], references: [id])
  quotes   JobQuote[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
}

model JobQuote {
  id            String   @id @default(cuid())
  jobId         String
  providerId    String   // the provider offering the quote
  price         Float    // quoted price in rupees
  message       String   // provider's pitch to the client
  estimatedTime String?  // "2 hours", "1 day", etc.
  status        String   @default("pending") // pending, accepted, rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider User @relation("JobQuoteProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([providerId])
  @@index([status])
}
