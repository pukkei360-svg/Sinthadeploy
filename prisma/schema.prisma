generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  firebaseUid   String?  @unique
  email         String   @unique
  name          String
  password      String?
  photoUrl      String?
  role          String   @default("client") // client, provider, admin
  phone         String?
  location      String?
  latitude      Float?
  longitude     Float?
  isVerified    Boolean  @default(false)
  isPro         Boolean  @default(false)
  proExpiry     DateTime?
  // isBlocked: legacy boolean — kept for backward compat. Now interpreted
  // as "temporarily suspended". Suspended users can't log in until admin
  // un-suspends them. Their data is preserved.
  isBlocked     Boolean  @default(false)
  // isBanned: permanent ban. Banned users can NEVER log in again. Their
  // email is also added to BannedEmail so they can't just create a new
  // account with the same email.
  isBanned      Boolean  @default(false)
  banReason     String?
  bannedAt      DateTime?
  fcmToken      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  providerProfile ProviderProfile?
  bookingsAsClient Booking[] @relation("ClientBookings")
  bookingsAsProvider Booking[] @relation("ProviderBookings")
  reviewsGiven Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")
  sentMessages ChatMessage[] @relation("MessageSender")
  verifications VerificationDoc[]
  subscriptions Subscription[]
  passwordResetTokens PasswordResetToken[]
  claimsFiled Claim[] @relation("ClaimReporter")
  claimsAgainst Claim[] @relation("ClaimSubject")
}

// BannedEmail — a blacklist of email addresses that can never be used
// to register or log in. Populated when an admin permanently bans a
// user. This is separate from User so that even after a User row is
// deleted, the email stays banned.
model BannedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  bannedAt  DateTime @default(now())
  bannedBy  String?  // admin user id
  createdAt DateTime @default(now())
}

// Claim — a complaint/report filed by a user against a provider
// (or another user). Visible in the admin panel under "Claims & Reports".
// Resolved claims stay in the DB for audit history.
model Claim {
  id          String   @id @default(cuid())
  // Who filed the claim
  reporterId  String
  // Who the claim is against
  subjectId   String
  // Optional: related booking (if the claim is about a specific job)
  bookingId   String?
  // Type of claim: fraud, misconduct, no_show, quality, payment, abuse, other
  type        String
  // Severity: low, medium, high, critical
  severity    String   @default("medium")
  // Short title / summary
  title       String
  // Detailed description from the reporter
  description String
  // Status: open, investigating, resolved, dismissed
  status      String   @default("open")
  // Admin resolution notes (filled when resolved/dismissed)
  resolution  String?
  // Admin who handled the claim
  handledBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User  @relation("ClaimReporter", fields: [reporterId], references: [id])
  subject  User  @relation("ClaimSubject", fields: [subjectId], references: [id])

  @@index([subjectId])
  @@index([reporterId])
  @@index([status])
}

model ServiceCategory {
  id          String @id @default(cuid())
  name        String
  icon        String?
  description String?
  order       Int    @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providers ProviderProfile[]
}

model ProviderProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  categoryId    String
  experience    String?
  skills        String?
  description   String?
  hourlyRate    Float?
  availability  String   @default("available") // available, busy, offline
  rating        Float    @default(0)
  totalReviews  Int      @default(0)
  totalBookings Int      @default(0)
  portfolioUrls String?  // JSON array of image URLs
  packages      String?  // JSON array of service packages (PRO)
  offers        String?  // JSON array of promotional offers (PRO)
  isFeatured    Boolean  @default(false)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings Booking[]      @relation("BookingProviderProfile")

  @@index([userId])
  @@index([categoryId])
}

model Booking {
  id          String   @id @default(cuid())
  clientId    String
  providerId  String
  service     String
  description String?
  date        DateTime
  time        String?
  status      String   @default("pending") // pending, accepted, in_progress, completed, cancelled, disputed
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   User           @relation("ClientBookings", fields: [clientId], references: [id])
  provider User           @relation("ProviderBookings", fields: [providerId], references: [id], map: "Booking_provider_user_fkey")
  providerProfile ProviderProfile @relation("BookingProviderProfile", fields: [providerId], references: [userId], map: "Booking_provider_profile_fkey")
  review   Review?

  @@index([clientId])
  @@index([providerId])
  @@index([status])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  authorId   String
  targetId   String
  rating     Int
  comment    String?
  photoUrls  String?  // JSON array
  createdAt  DateTime @default(now())

  author User    @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User    @relation("ReviewTarget", fields: [targetId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([targetId])
}

model ChatConversation {
  id           String   @id @default(cuid())
  participantA String
  participantB String
  bookingId    String?
  lastMessage  String?
  lastMessageAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages ChatMessage[]

  @@index([participantA])
  @@index([participantB])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("text") // text, image, voice, location
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model VerificationDoc {
  id         String   @id @default(cuid())
  userId     String
  docType    String   // aadhaar, selfie, address_proof
  docUrl     String
  status     String   @default("pending") // pending, verified, rejected
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  plan            String   @default("pro")
  razorpayOrderId String?
  razorpayPaymentId String?
  amount          Float
  currency        String   @default("INR")
  status          String   @default("active") // active, expired, cancelled
  startDate       DateTime @default(now())
  endDate         DateTime
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // booking, chat, review, system, pro
  isRead    Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
