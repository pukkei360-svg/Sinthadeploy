# ============================================================
# SINTHA - Environment Variables
# ============================================================
# Copy this file to ".env.local" for local development, OR set
# these in your Vercel dashboard under Project → Settings →
# Environment Variables (tick "All Environments").
# ============================================================

# ---- Database (PostgreSQL on Vercel / Neon / Supabase) ----
# Local dev:  postgresql://user:pass@localhost:5432/sintha
# Vercel:     Auto-provided when you create a Vercel Postgres DB
#             (or paste a Neon/Supabase connection string here)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# ---- Razorpay (TEST keys - rzp_test_*) ----
# Get from: https://dashboard.razorpay.com/applicants/keys
RAZORPAY_KEY_ID="rzp_test_T2JofJcoa6lHKm"
RAZORPAY_KEY_SECRET="m2qt1WsbwFe7jc53qtXNQFap"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_T2JofJcoa6lHKm"

# ---- Razorpay (LIVE keys - rzp_live_*) ----
# Replace test keys with these once your KYC is approved
# RAZORPAY_KEY_ID="rzp_live_your_live_key_id"
# RAZORPAY_KEY_SECRET="your_live_key_secret"
# NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_your_live_key_id"

# ---- Razorpay Webhook Secret ----
# Get from: Razorpay Dashboard → Settings → Webhooks → Add New Webhook
# Enter your Vercel URL: https://your-app.vercel.app/api/razorpay/webhook
# Copy the "Webhook Secret" Razorpay shows you and paste it below
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_from_razorpay"

# ---- Firebase Config ----
